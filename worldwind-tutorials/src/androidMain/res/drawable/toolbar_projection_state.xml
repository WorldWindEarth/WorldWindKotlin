<?xml version="1.0" encoding="utf-8"?>
<!--
    3D-projection indicator for the camera-frustum toggle. Checked = perspective
    frustum (3D camera-frustum projection), unchecked = planar homography drape.
    Used as the `android:button` of the is3d CheckBox.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true"  android:drawable="@drawable/ic_projection_perspective" />
    <item                                 android:drawable="@drawable/ic_projection_planar" />
</selector>
